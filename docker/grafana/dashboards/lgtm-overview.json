          "showLegend": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(demo_api_requests_total{demo_scenario_status=\"error\"}[5m])) / clamp_min(sum(rate(demo_api_requests_total[5m])), 0.0001)",
          "legendFormat": "error_ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error Ratio (%)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.95, sum(rate(traces_spanmetrics_latency_bucket{service=\"lgtm-demo-api\", span_kind=\"SPAN_KIND_SERVER\"}[5m])) by (le))",
          "legendFormat": "p95",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "editorMode": "code",
          "expr": "1000 * histogram_quantile(0.50, sum(rate(traces_spanmetrics_latency_bucket{service=\"lgtm-demo-api\", span_kind=\"SPAN_KIND_SERVER\"}[5m])) by (le))",
          "legendFormat": "p50",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "API Latency (ms)",
      "type": "timeseries"
    },
