      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "editorMode": "code",
          "expr": "sum(rate(demo_api_requests_total[1m])) by (demo_scenario_status)",
          "legendFormat": "{{demo_scenario_status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Request Rate by Status",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "decimals": 2,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
